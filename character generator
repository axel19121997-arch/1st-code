# projet Naheykbeuk
import tkinter as tk
import random

# Données du jeu
races = [
    "Humain",
    "Ogre",
    "Elfe",
    "Thérianthropes",
    "Nain",
    "Elfe noir",
    "Mort vivant",
    "Orc"
    
]

classes = [
    "Guerrier",
    "Évêque",
    "Mage",
    "Assassin",
    "Paladin",
    "Archer",
    "Menestrel",
    "Chaman"
]

objets = [
    "Épée très rouillée",
    "Pioche de nain",
    "Arc déformé",
    "Sandwich au pâté",
    "Potion amère",
    "Armure trouée",
    "Casque cabossé",
    "Dague fragilisée",
    "Baton très peu magique",
    "Harpe abîmée",
    "Lance courte",
    "Bière fraiche"
]

particularites = [
    "Ne tient pas l'aclool",
    "Chante faux",
    "Déclenche tous les pièges",
    "Stress élevé",
    "Perd son équipement",
    "Parle aux voix dans sa tête",
    "BASTOOOOON",
    "Moa po savoire perlai",
    "Comprend vite mais à besoin de temps",
    "Tape lentement mais fort",
    "Beau de loin mais loin d'être sûre"
]

noms = [
    "Albert",
    "Jean-kevin",
    "Mysti",
    "Andora",
    "Simonie",
    "Alfred",
    "Norbert",
    "Camillia",
    "Sigmud",
    "Ingrid",
    "Gorgir"
]

surnoms = [
    "Le Puant",
    "Sans peur",
    "Le Trouillard",
    "Le Vénérable",
    "3 Pates",
    "Le Goinfre",
    "Terreur des Tavernes",
    "L'Assoiffé",
    "La Patronne",
    "La Sainte"
]

def generer_personnage():

    nom = entree_nom.get().strip()

    if nom == "":
        nom = f"{random.choice(noms)} {random.choice(surnoms)}"
    else:
        nom = nom.title()
        
    race = random.choice(races)
    classe = random.choice(classes)
    objet = random.sample(objets, 3)
    particularite = random.sample(particularites, 2)

    courage = random.randint(8, 20)
    intelligence = random.randint(8, 20)
    force = random.randint(8, 20)
    adresse = random.randint(8, 20)

    texte = f"""
📇 FICHE D'AVENTURIER 📇

Nom : {nom}

Race : {race}
Classe : {classe}

⚔ Courage : {courage}
🧠 Intelligence : {intelligence}
💪 Force : {force}
🏹 Adresse : {adresse}

🎒 Objet :
{objet}

😂 Particularité :
{particularite}
"""

    resultat.config(text=texte)


# Fenêtre principale
fenetre = tk.Tk()
fenetre.title("Le Donjon de Naheulbeuk")
fenetre.geometry("650x650")
fenetre.configure(bg="#2d1b0f")

# Titre
titre = tk.Label(
    fenetre,
    text="LE DONJON DE NAHEULBEUK",
    font=("Times New Roman", 24, "bold"),
    fg="gold",
    bg="#2d1b0f"
)
titre.pack(pady=15)

# Nom
label_nom = tk.Label(
    fenetre,
    text="Nom du héros :",
    fg="white",
    bg="#2d1b0f",
    font=("Arial", 12)
)
label_nom.pack()

entree_nom = tk.Entry(
    fenetre,
    width=30,
    font=("Arial", 12)
)
entree_nom.pack(pady=10)

# Bouton
bouton = tk.Button(
    fenetre,
    text="Créer un aventurier",
    font=("Arial", 14),
    command=generer_personnage,
    bg="#8b4513",
    fg="white",
    activebackground="#a0522d",
    activeforeground="gold"
)
bouton.pack(pady=15)

# Zone résultat
resultat = tk.Label(
    fenetre,
    text="",
    justify="left",
    anchor="w",
    fg="white",
    bg="#2d1b0f",
    font=("Courier New", 12)
)

resultat.pack(padx=20, pady=20)

fenetre.mainloop()
