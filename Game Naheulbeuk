def evenement_choix(option):
    frame_evenement.pack_forget()
    if option == "discret":
        stat_eff = heros["adresse"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "adresse" else 0)
        if random.randint(1, 20) <= stat_eff:
            heros["xp"] += 20
            journal.config(text="Incroyable, l'Ogre n'a fait aucun bruit. Vous passez inaperçus ! (+20 XP)", fg="lightgreen")
            log_victoire_calculs(0, 20)
            return
        else:
            degats = random.randint(10, 15)
            heros["pv"] -= degats
            journal.config(text=f"Le Voleur a trébuché sur un tabouret. Les Orcs vous tirent dessus avant de sonner l'alarme ! (-{degats} PV)", fg="red")
            verifier_mort()
    elif option == "baston":
        stat_eff = heros["courage"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "courage" else 0)
        if random.randint(1, 20) <= stat_eff:
            butin = random.randint(15, 30)
            heros["or"] += butin
            journal.config(text=f"Votre folie furieuse les terrorise ! Ils lâchent leur bourse et détalent. (+{butin} pièces)", fg="lightgreen")
        else:
            degats = random.randint(8, 12)
            heros["pv"] -= degats
            journal.config(text=f"La charge rate lamentablement. Vous prenez quelques coups avant de les semer. (-{degats} PV)", fg="red")
            verifier_mort()
    
    if heros["pv"] > 0:
        btn_continuer_loot.config(text="🎒 Reprendre la route")
        btn_continuer_loot.pack(pady=5)

def generer_loot_coffre():
    chance = random.randint(1, 100)
    if chance > 90:
        rarete, dmg, stat_val, couleur = "Légendaire", random.randint(10, 16), random.randint(4, 7), "#ff4500"
        nom_arme = f"{random.choice(prefix_armes)} {random.choice(suffix_legendaire)}"
    elif chance > 60:
        rarete, dmg, stat_val, couleur = "Rare", random.randint(5, 9), random.randint(2, 4), "#1e90ff"
        nom_arme = f"{random.choice(prefix_armes)} {random.choice(suffix_rare)}"
    else:
        rarete, dmg, stat_val, couleur = "Commun", random.randint(2, 4), random.randint(1, 2), "white"
        nom_arme = f"{random.choice(prefix_armes)} {random.choice(suffix_commun)}"

    stat_attribuee = random.choice(["force", "intelligence", "adresse", "courage"])
    heros["arme"] = {"nom": nom_arme, "rare": rarete, "dmg": dmg, "stat": stat_attribuee, "stat_val": stat_val}
    
    pieces = random.randint(10, 25)
    heros["or"] += pieces
    
    log = f"📦 SURPRISE ! Un Coffre poussiéreux se cachait là !\nTu l'équipes de force : {nom_arme} [{rarete}] (+{dmg} Dmg)\nButin supplémentaire : +{pieces} pièces d'or !"
    journal.config(text=log, fg=couleur)
    rafraichir_affichage_heros()

