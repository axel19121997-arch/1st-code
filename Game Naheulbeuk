        btn_comp2.config(text=f"🔒 {info_c['sort2']} (Niv 3)", state="disabled", bg="grey")
    frame_actions_combat.pack(pady=10)

def riposte_monstre():
    if monstre_actuel["pv"] > 0:
        stat_force = heros["force"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "force" else 0)
        degats_monstre = max(1, (random.randint(2, 6) + (monstre_actuel["force"] // 3)) - (stat_force // 6))
        heros["pv"] -= degats_monstre
        rafraichir_affichage_heros()
        verifier_mort()
        return f"\nLe monstre riposte et t'inflige {degats_monstre} dégâts !"
    return ""

def attaquer():
    global monstre_actuel
    stat_force = heros["force"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "force" else 0)
    degats_heros = random.randint(3, 7) + (stat_force // 4) + heros["arme"]["dmg"]
    monstre_actuel["pv"] -= degats_heros
    log = f"Tu cognes de toutes tes forces ! {degats_heros} dégâts infligés."
    
    if monstre_actuel["pv"] <= 0:
        gerer_victoire_combat()
    else:
        log += riposte_monstre()
        journal.config(text=f"{log}\n({monstre_actuel['nom']} PV: {monstre_actuel['pv']})", fg="pink")

def cast_sort(num_sort):
    global monstre_actuel
    info_c = classes_data[heros["classe"]]
    nom_s = info_c["sort1"] if num_sort == 1 else info_c["sort2"]
    cout = info_c["cout1"] if num_sort == 1 else info_c["cout2"]

    if heros["mana"] < cout:
        journal.config(text=f"❌ Énergie insuffisante !", fg="yellow")
        return

    heros["mana"] -= cout
    log = ""
    sf = heros["force"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "force" else 0)
    si = heros["intelligence"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "intelligence" else 0)
    sc = heros["courage"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "courage" else 0)
    ab = heros["arme"]["dmg"]

    if nom_s == "Coup de Bouclier":
        d = random.randint(6, 12) + (sf // 3) + ab; monstre_actuel["pv"] -= d; log = f"🛡️ Coup de Bouclier ! ({d} dégâts)"
    elif nom_s == "Exécution":
        d = random.randint(18, 30) + (sf // 2) + ab; monstre_actuel["pv"] -= d; log = f"🪓 EXÉCUTION ! ({d} dégâts)"
    elif nom_s == "Soins Mineurs":
        s = random.randint(12, 22) + (si // 3); heros["pv"] = min(heros["pv_max"], heros["pv"] + s); log = f"✨ Soin ! (+{s} PV)"
    elif nom_s == "Colère Divine":
        d = random.randint(10, 18) + (si // 4); s = 8; monstre_actuel["pv"] -= d; heros["pv"] = min(heros["pv_max"], heros["pv"] + s); log = f"⚡ Éclat Sacré ! ({d} dégâts)"
    elif nom_s == "Boule de Feu":
        d = random.randint(12, 24) + (si // 2) + (ab * 2); monstre_actuel["pv"] -= d; log = f"🔥 Boule de Feu ! ({d} dégâts)"
    elif nom_s == "Éclair Enchaîné":
        d = random.randint(25, 45) + si; monstre_actuel["pv"] -= d; log = f"⚡ GRANDE FOUDRE ! ({d} dégâts)"
    elif nom_s == "Attaque Sournoise":
        d = (25 + ab) if random.choice([True, False]) else 5; monstre_actuel["pv"] -= d; log = f"🗡️ Coup sournois ! ({d} dégâts)"
    elif nom_s == "Lame Toxique":
        d = 16 + (heros["adresse"] // 3); monstre_actuel["pv"] -= d; log = f"🧪 Lame Empoisonnée ! ({d} dégâts)"
    elif nom_s == "Justice Divine":
        d = 8 + (sc // 4) + ab; heros["pv"] = min(heros["pv_max"], heros["pv"] + 5); monstre_actuel["pv"] -= d; log = f"⚖️ Justice ! ({d} dégâts)"
    elif nom_s == "Bouclier Lumineux":
        s = random.randint(22, 35); heros["pv"] = min(heros["pv_max"], heros["pv"] + s); log = f"🛡️ Grand Soin Lumineux (+{s} PV) !"
    elif nom_s == "Tir Précis":
        d = 12 + ab; monstre_actuel["pv"] -= d; log = f"🏹 Flèche perforante. ({d} dégâts)"
    elif nom_s == "Pluie de Flèches":
        tirs = random.randint(3, 5); d = tirs * (4 + (heros["adresse"] // 5)); monstre_actuel["pv"] -= d; log = f"🏹 Pluie de flèches ! ({d} dégâts total)"
    elif nom_s == "Chanson Débile":
        d = random.randint(1, 30) + ab; monstre_actuel["pv"] -= d; log = f"🎵 Chanson débile ! ({d} dégâts)"
    elif nom_s == "Flûte Insupportable":
        d = random.randint(20, 50); monstre_actuel["pv"] -= d; log = f"🪈 Musique atroce ! ({d} dégâts)"
    elif nom_s == "Esprit Totem":
        d = random.randint(4, 10) + (sc // 2) + ab; monstre_actuel["pv"] -= d; log = f"🦫 Esprit du Castor ! ({d} dégâts)"
    elif nom_s == "Sort du Poulet":
        d = monstre_actuel["pv"] // 2 + 5; monstre_actuel["pv"] -= d; log = f"🐔 Métamorphose en Poulet ! (-{d} PV)"

    if monstre_actuel["pv"] <= 0:
        gerer_victoire_combat()
    else:
        log += riposte_monstre()
        journal.config(text=f"{log}\n({monstre_actuel['nom']} PV: {monstre_actuel['pv']})", fg="magenta")
    rafraichir_affichage_heros()

def gerer_victoire_combat():
    frame_actions_combat.pack_forget()
    if "ZANGDAR" in monstre_actuel["nom"]:
        journal.config(text="🏆 VICTOIRE SUPRÊME !!! 🏆\nZangdar mord la poussière ! Vous récupérez la Statuette de Gladeulfeurha ! L'histoire retiendra que vous étiez des bras cassés, mais des bras cassés riches !", fg="gold")
        return
    or_gagne = random.randint(5, 15)
    heros["or"] += or_gagne
    log_victoire_calculs(or_gagne, monstre_actuel["xp"])

def log_victoire_calculs(or_gagne, xp_gagne):
    heros["xp"] += xp_gagne
    log = f"🎉 Le monstre s'effondre ! +{xp_gagne} XP | +{or_gagne} pièces d'or."
    if heros["xp"] >= heros["xp_requis"]:
        heros["niveau"] += 1; heros["xp"] -= heros["xp_requis"]
        heros["pv_max"] += 10; heros["mana_max"] += 5
        heros["pv"] = heros["pv_max"]; heros["mana"] = heros["mana_max"]
        heros["force"] += 2; heros["intelligence"] += 2; heros["adresse"] += 2; heros["courage"] += 2
        log += f"\n\n🌟 LEVEL UP !! Tu passes Niveau {heros['niveau']} ! Stats augmentées !"

    journal.config(text=log, fg="lightgreen")
    btn_continuer_loot.config(text="🎒 Continuer l'exploration")
    btn_continuer_loot.pack(pady=5)

def fermer_loot_et_avancer():
    btn_continuer_loot.pack_forget()
    generer_choix_chemins()

def fuir():
    journal.config(text="Tu as fui par la porte de derrière !", fg="yellow")
    frame_actions_combat.pack_forget()
    generer_choix_chemins()

def verifier_mort():
    if heros["pv"] <= 0:
        heros["pv"] = 0
        rafraichir_affichage_heros()
        journal.config(text="💀 T'es mort. La Compagnie cherche un remplaçant sur l'intranet du Donjon.", fg="red")
        frame_actions_combat.pack_forget()
        frame_chemins.pack_forget()
        frame_taverne.pack_forget()
        frame_evenement.pack_forget()


