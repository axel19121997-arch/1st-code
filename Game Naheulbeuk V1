# 3. SYSTÈME DE JEU

def generer_personnage():
    global heros
    nom_saisi = entree_nom.get().strip()

    genre = random.choice(["homme", "femme"]) if genre_selectionne == "Aléatoire" else genre_selectionne

    if nom_saisi == "":
        prenom = random.choice(noms_masculins if genre == "homme" else noms_feminins)
        surnom = random.choice(surnoms_masculins if genre == "homme" else surnoms_feminins)
        nom = f"{prenom} {surnom}"
    else:
        nom = nom_saisi

    race = random.choice(races) if race_selectionnee == "Aléatoire" else race_selectionnee
    classe = random.choice(classes) if classe_selectionnee == "Aléatoire" else classe_selectionnee

    courage = random.randint(8, 16)
    intelligence = random.randint(8, 16)
    force = random.randint(8, 16)
    adresse = random.randint(8, 16)

    info_classe = classes_data[classe]
    if info_classe["bonus"] == "force": force += info_classe["valeur"]
    elif info_classe["bonus"] == "intelligence": intelligence += info_classe["valeur"]
    elif info_classe["bonus"] == "adresse": adresse += info_classe["valeur"]
    elif info_classe["bonus"] == "courage": courage += info_classe["valeur"]
    elif info_classe["bonus"] == "tous":
        force += info_classe["valeur"]; intelligence += info_classe["valeur"]
        adresse += info_classe["valeur"]; courage += info_classe["valeur"]

    arme_depart = info_classe["arme"].copy()

    heros = {
        "nom": nom, "genre": genre, "race": race, "classe": classe,
        "courage": courage, "intelligence": intelligence, "force": force, "adresse": adresse,
        "pv": 50, "pv_max": 50,
        "particularites": random.sample(particularites, 2),
        "sort": info_classe["sort"],
        "arme": arme_depart
    }

    rafraichir_affichage_heros()
    btn_competence.config(text=f"✨ {heros['sort']}")
    bouton_explorer.pack(pady=10)
    frame_actions_combat.pack_forget()

def rafraichir_affichage_heros():
    f_bonus = heros["arme"]["stat_val"] if heros["arme"]["stat"] == "force" else 0
    i_bonus = heros["arme"]["stat_val"] if heros["arme"]["stat"] == "intelligence" else 0
    a_bonus = heros["arme"]["stat_val"] if heros["arme"]["stat"] == "adresse" else 0
    c_bonus = heros["arme"]["stat_val"] if heros["arme"]["stat"] == "courage" else 0

    rare_txt = f"[{heros['arme']['rare']}]"

    texte = f"""📇 FICHE D'AVENTURIER 📇
Nom : {heros['nom']} ({heros['genre']}) - {heros['race']} {heros['classe']}
❤️ PV : {heros['pv']}/{heros['pv_max']}

⚔ Courage : {heros['courage'] + c_bonus} ({heros['courage']}+{c_bonus})   🧠 Intelligence : {heros['intelligence'] + i_bonus} ({heros['intelligence']}+{i_bonus})
💪 Force : {heros['force'] + f_bonus} ({heros['force']}+{f_bonus})      🏹 Adresse : {heros['adresse'] + a_bonus} ({heros['adresse']}+{a_bonus})

⚔️ Arme Équipée : {heros['arme']['nom']} {rare_txt}
   💥 Dégâts de l'arme : +{heros['arme']['dmg']} | 🌟 Bonus : +{heros['arme']['stat_val']} {heros['arme']['stat'].upper()}

😂 Particularités : - {heros['particularites'][0]} | {heros['particularites'][1]}"""
    resultat.config(text=texte)

def explorer():
    if heros.get("pv", 0) <= 0: return

    evenement = random.choice(["combat", "combat", "coffre", "vide", "piege"])
    
    if evenement == "vide":
        journal.config(text="Tu marches dans un couloir sombre. Ça sent les pieds. Rien ne se passe.", fg="white")
    
    elif evenement == "coffre":
        generer_loot_coffre()
        
    elif evenement == "piege":
        stat_adresse = heros["adresse"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "adresse" else 0)
        if random.randint(1, 25) < stat_adresse:
            journal.config(text="Un piège se déclenche, mais grâce à ton ADRESSE, tu sautes par-dessus au dernier moment !", fg="lightgreen")
        else:
            degats = random.randint(6, 12)
            heros["pv"] -= degats
            journal.config(text=f"Tu as marché sur une dalle suspecte... Un dictionnaire te tombe dessus ! Tu perds {degats} PV.", fg="orange")
            rafraichir_affichage_heros()
            verifier_mort()

    elif evenement == "combat":
        commencer_combat()

def generer_loot_coffre():
    chance = random.randint(1, 100)
    if chance > 90:
        rarete = "Légendaire"
        nom_arme = f"{random.choice(prefix_armes)} {random.choice(suffix_legendaire)}"
        dmg = random.randint(10, 16)
        stat_val = random.randint(4, 7)
        couleur = "#ff4500" 
    elif chance > 60:
        rarete = "Rare"
        nom_arme = f"{random.choice(prefix_armes)} {random.choice(suffix_rare)}"
        dmg = random.randint(5, 9)
        stat_val = random.randint(2, 4)
        couleur = "#1e90ff" 
    else:
        rarete = "Commun"
        nom_arme = f"{random.choice(prefix_armes)} {random.choice(suffix_commun)}"
        dmg = random.randint(2, 4)
        stat_val = random.randint(1, 2)
        couleur = "white"

    stat_attribuee = random.choice(["force", "intelligence", "adresse", "courage"])
    
    nouvelle_arme = {
        "nom": nom_arme, "rare": rarete, "dmg": dmg, "stat": stat_attribuee, "stat_val": stat_val
    }

    heros["arme"] = nouvelle_arme
    
    log = f"📦 COFFRE AU TRÉSOR ! Tu l'ouvres de façons hésitantes.\n"
    log += f"Tu trouves : {nom_arme} [{rarete}]\n"
    log += f"Stats : +{dmg} Dégâts de base | +{stat_val} {stat_attribuee.upper()}\n"
    log += "Tu jettes ton ancienne arme sans aucun remords et tu équipes la nouvelle !"
    
    journal.config(text=log, fg=couleur)
    rafraichir_affichage_heros()

def commencer_combat():
    global monstre_actuel
    monstre_actuel = random.choice(monstres).copy()
    journal.config(text=f"💥 ALERTE BASTON ! {monstre_actuel['nom']} surgit ! (PV: {monstre_actuel['pv']})", fg="red")
    bouton_explorer.pack_forget()
    frame_actions_combat.pack(pady=10)

def riposte_monstre():
    if monstre_actuel["pv"] > 0:
        stat_force = heros["force"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "force" else 0)
        degats_monstre = max(1, (random.randint(2, 6) + (monstre_actuel["force"] // 3)) - (stat_force // 6))
        heros["pv"] -= degats_monstre
        rafraichir_affichage_heros()
        verifier_mort()
        return f"\nLe monstre riposte et t'inflige {degats_monstre} dégâts !"
    return ""

def attaquer():
    global monstre_actuel
    stat_force = heros["force"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "force" else 0)
    
    degats_heros = random.randint(3, 7) + (stat_force // 4) + heros["arme"]["dmg"]
    monstre_actuel["pv"] -= degats_heros
    log = f"Tu cognes plus ou moins fort avec ton outil ({heros['arme']['nom']}) et infliges {degats_heros} dégâts."
    
    if monstre_actuel["pv"] <= 0:
        journal.config(text=log + f"\n🎉 VICTOIRE sur {monstre_actuel['nom']} ! Enfin, ce n'était pas si impressionnant...", fg="lightgreen")
        fin_combat()
    else:
        log += riposte_monstre()
        journal.config(text=f"{log}\n({monstre_actuel['nom']} PV: {monstre_actuel['pv']})", fg="pink")

def utiliser_competence():
    global monstre_actuel
    sort = heros["sort"]
    log = ""
    
    sf = heros["force"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "force" else 0)
    si = heros["intelligence"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "intelligence" else 0)
    sc = heros["courage"] + (heros["arme"]["stat_val"] if heros["arme"]["stat"] == "courage" else 0)
    
    arme_bonus = heros["arme"]["dmg"]
    
    if sort == "Coup de Bouclier":
        degats = random.randint(6, 12) + (sf // 3) + arme_bonus
        monstre_actuel["pv"] -= degats
        log = f"🛡️ Coup de Bouclier ! BASTON ! ({degats} dégâts)"
        
    elif sort == "Soins Mineurs":
        soin = random.randint(10, 20) + (si // 3)
        heros["pv"] = min(heros["pv_max"], heros["pv"] + soin)
        log = f"✨ Tu lances un sort de soin et récupères {soin} PV !"
        
    elif sort == "Boule de Feu":
        degats = random.randint(12, 24) + (si // 2) + (arme_bonus * 2)
        monstre_actuel["pv"] -= degats
        log = f"🔥 ÉNORME EXPLOSION DE FEU ! ({degats} dégâts)"
        
    elif sort == "Attaque Sournoise":
        if random.choice([True, False]):
            degats = 25 + arme_bonus
            log = f"🗡️ CRITIQUE ! Dans le dos ! ({degats} dégâts)"
        else:
            degats = 5
            log = f"🗡️ Raté... Tu as glissé sur une touffe d'herbe. (5 dégâts)"
        monstre_actuel["pv"] -= degats
        
    elif sort == "Justice Divine":
        degats = 8 + (sc // 4) + arme_bonus
        soin = 6
        monstre_actuel["pv"] -= degats
        heros["pv"] = min(heros["pv_max"], heros["pv"] + soin)
        log = f"⚖️ Justice ! Frappe ({degats} dégâts) et soin (+{soin} PV)."
        
    elif sort == "Tir Précis":
        degats = 12 + arme_bonus
        monstre_actuel["pv"] -= degats
        log = f"🏹 Flèche transperçante ! ({degats} dégâts)"
        
    elif sort == "Chanson Débile":
        degats = random.randint(1, 30) + arme_bonus
        monstre_actuel["pv"] -= degats
        log = f"🎵 Le monstre saigne des oreilles à cause de ta musique ! ({degats} dégâts)"
        
    elif sort == "Esprit Totem":
        degats = random.randint(4, 10) + (sc // 2) + arme_bonus
        monstre_actuel["pv"] -= degats
        log = f"🦫 L'esprit du castor enragé te donne de la force ! ({degats} dégâts)"

    if monstre_actuel["pv"] <= 0:
        journal.config(text=log + f"\n🎉 Victoire sur {monstre_actuel['nom']} !", fg="lightgreen")
        fin_combat()
    else:
        log += riposte_monstre()
        journal.config(text=f"{log}\n({monstre_actuel['nom']} PV: {monstre_actuel['pv']})", fg="pink")
    rafraichir_affichage_heros()

def fuir():
    journal.config(text="Tu as fui comme un lâche, qui n'aurait pas honte !", fg="yellow")
    fin_combat()

def fin_combat():
    frame_actions_combat.pack_forget()
    if heros["pv"] > 0: bouton_explorer.pack(pady=10)

def verifier_mort():
    if heros["pv"] <= 0:
        heros["pv"] = 0
        rafraichir_affichage_heros()
        journal.config(text="💀 T'es mort, c'est la fin de cette aventure. GAME OVER.", fg="red")
        frame_actions_combat.pack_forget()
        bouton_explorer.pack_forget()


