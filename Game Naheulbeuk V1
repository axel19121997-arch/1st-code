bouton_creer.pack(side="left", padx=5)

resultat = tk.Label(fenetre, text="Crée un aventurier...", justify="left", anchor="w", fg="white", bg="#1a1009", font=("Courier New", 10), bd=2, relief="groove", padx=15, pady=10)
