# projet Naheykbeuk
import tkinter as tk
import random

# 1. DONNÉES DU JEU

races = ["Humain", "Ogre", "Elfe", "Thérianthropes", "Nain", "Elfe noir", "Mort vivant", "Orc"]
classes = ["Guerrier", "Évêque", "Mage", "Assassin", "Paladin", "Archer", "Menestrel", "Chaman"]

objets = [
    "Épée très rouillée", "Pioche de nain", "Arc déformé", "Sandwich au pâté",
    "Potion amère", "Armure trouée", "Casque cabossé", "Dague fragilisée",
    "Baton très peu magique", "Harpe abîmée", "Lance courte", "Bière fraiche"
]

particularites = [
    "Ne tient pas l'aclool", "Chante faux", "Déclenche tous les pièges",
    "Stress élevé", "Perd son équipement", "Parle aux voix dans sa tête",
    "BASTOOOOON", "Moa po savoire perlai", "Comprend vite mais à besoin de temps",
    "Tape lentement mais fort", "Beau de loin mais loin d'être sûre"
]

noms_masculins = ["Albert", "Jean-kevin", "Alfred", "Norbert", "Sigmud", "Gorgir", "Bargor", "Phillipus", "Eudyr", "Mortanaelle"]
noms_feminins = ["Mysti", "Andora", "Simonie", "Camillia", "Ingrid", "Isabella", "Monique", "Claudette", "Susette", "Mélissa"]

surnoms_masculins = ["Le Puant", "Sans peur", "Le Trouillard", "Le Vénérable", "3 Pates", "Le Goinfre", "Terreur des Tavernes", "L'Assoiffé", "Le Destructeur", "Sans Renom"]
surnoms_feminins = ["La Patronne", "La Sainte", "La Mystérieuse", "La Roublarde", "La Couarde", "La Puissante", "L'Assoupie", "La Guerrière", "Beautée Fatale", "La Sage"]

genre_selectionne = "Aléatoire"
race_selectionnee = "Aléatoire"
classe_selectionnee = "Aléatoire"



# 2. FONCTIONS LOGIQUES

def choisir_genre(genre, bouton_clique):
    global genre_selectionne
    genre_selectionne = genre
    
    for bouton in frame_genre.winfo_children():
        bouton.config(bg="#f0f0f0", fg="black") 
    
    bouton_clique.config(bg="gold", fg="black")

def choisir_race(race, bouton_clique):
    global race_selectionnee
    race_selectionnee = race
    
    for bouton in frame_race.winfo_children():
        bouton.config(bg="#f0f0f0", fg="black")
        
    bouton_clique.config(bg="#32cd32", fg="white") 

def choisir_classe(classe, bouton_clique):
    global classe_selectionnee
    classe_selectionnee = classe
    
    for bouton in frame_classe.winfo_children():
        bouton.config(bg="#f0f0f0", fg="black")
        
    bouton_clique.config(bg="#32cd32", fg="white")

def generer_personnage():  
    nom_saisi = entree_nom.get().strip()

    # Sexe
    if genre_selectionne == "Aléatoire":
        genre = random.choice(["homme", "femme"])
    else:
        genre = genre_selectionne

    # Nom
    if nom_saisi == "":
        if genre == "homme":
            prenom = random.choice(noms_masculins)
            surnom = random.choice(surnoms_masculins)
        else:
            prenom = random.choice(noms_feminins)
            surnom = random.choice(surnoms_feminins)
        nom = f"{prenom} {surnom}"
    else:
        nom = nom_saisi

    # Race
    if race_selectionnee == "Aléatoire":
        race = random.choice(races)
    else:
        race = race_selectionnee

    # Classe
    if classe_selectionnee == "Aléatoire":
        classe = random.choice(classes)
    else:
        classe = classe_selectionnee

    objets_choisis = random.sample(objets, 3)
    particularites_choisies = random.sample(particularites, 2)

    courage = random.randint(8, 20)
    intelligence = random.randint(8, 20)
    force = random.randint(8, 20)
    adresse = random.randint(8, 20)

    texte = f"""
📇 FICHE D'AVENTURIER 📇

Nom : {nom}
Genre : {genre}
Race : {race}
Classe : {classe}

⚔ Courage : {courage}
🧠 Intelligence : {intelligence}
💪 Force : {force}
🏹 Adresse : {adresse}

🎒 Objets :
- {objets_choisis[0]}
- {objets_choisis[1]}
- {objets_choisis[2]}

😂 Particularités :
- {particularites_choisies[0]}
- {particularites_choisies[1]}
"""
    resultat.config(text=texte)



# 3. CRÉATION DE L'INTERFACE 

fenetre = tk.Tk()
fenetre.title("Le Donjon de Naheulbeuk")
fenetre.geometry("800x750") # Légèrement élargi pour les boutons
fenetre.configure(bg="#2d1b0f")

# Titre
titre = tk.Label(
    fenetre,
    text="LE DONJON DE NAHEULBEUK",
    font=("Times New Roman", 24, "bold"),
    fg="gold",
    bg="#2d1b0f"
)
titre.pack(pady=15)

# --- Sexe ---
tk.Label(fenetre, text="Sexe", fg="gold", bg="#2d1b0f", font=("Arial", 12, "bold")).pack(pady=2)
frame_genre = tk.Frame(fenetre, bg="#2d1b0f")
frame_genre.pack()

btn_homme = tk.Button(frame_genre, text="👨 Homme")
btn_homme.config(command=lambda: choisir_genre("homme", btn_homme))
btn_homme.pack(side="left", padx=5)

btn_femme = tk.Button(frame_genre, text="👩 Femme")
btn_femme.config(command=lambda: choisir_genre("femme", btn_femme))
btn_femme.pack(side="left", padx=5)

btn_rand_g = tk.Button(frame_genre, text="🎲 Aléatoire", bg="gold") # De base sur "Aléatoire"
btn_rand_g.config(command=lambda: choisir_genre("Aléatoire", btn_rand_g))
btn_rand_g.pack(side="left", padx=5)

# --- Race ---
tk.Label(fenetre, text="Race", fg="gold", bg="#2d1b0f", font=("Arial", 12, "bold")).pack(pady=5)
frame_race = tk.Frame(fenetre, bg="#2d1b0f")
frame_race.pack()

for race in races:
    btn_r = tk.Button(frame_race, text=race)
    btn_r.config(command=lambda r=race, b=btn_r: choisir_race(r, b))
    btn_r.pack(side="left", padx=2)

btn_rand_r = tk.Button(frame_race, text="🎲 Random", bg="#32cd32", fg="white") # De base sur "Random"
btn_rand_r.config(command=lambda: choisir_race("Aléatoire", btn_rand_r))
btn_rand_r.pack(side="left", padx=2)

# --- Classe ---
tk.Label(fenetre, text="Classe", fg="gold", bg="#2d1b0f", font=("Arial", 12, "bold")).pack(pady=5)
frame_classe = tk.Frame(fenetre, bg="#2d1b0f")
frame_classe.pack()

for classe in classes:
    btn_c = tk.Button(frame_classe, text=classe)
    btn_c.config(command=lambda c=classe, b=btn_c: choisir_classe(c, b))
    btn_c.pack(side="left", padx=2)

btn_rand_c = tk.Button(frame_classe, text="🎲 Random", bg="#32cd32", fg="white") # De base sur "Random"
btn_rand_c.config(command=lambda: choisir_classe("Aléatoire", btn_rand_c))
btn_rand_c.pack(side="left", padx=2)

# --- Entrée Nom ---
label_nom = tk.Label(fenetre, text="Nom du héros (laisser vide pour de l'aléatoire) :", fg="white", bg="#2d1b0f", font=("Arial", 12))
label_nom.pack(pady=(15, 0))

entree_nom = tk.Entry(fenetre, width=30, font=("Arial", 12))
entree_nom.pack(pady=5)

# --- Bouton de génération ---
bouton = tk.Button(
    fenetre, text="Créer un aventurier", font=("Arial", 14, "bold"),
    command=generer_personnage, bg="#8b4513", fg="white",
    activebackground="#a0522d", activeforeground="gold"
)
bouton.pack(pady=15)

# --- Zone résultat ---
resultat = tk.Label(
    fenetre, text="", justify="left", anchor="w",
    fg="white", bg="#2d1b0f", font=("Courier New", 11)
)
resultat.pack(padx=20, pady=10)

# Lancement du jeu
fenetre.mainloop()
